# MindVault Environment Variables

# Server Port (Fixed to 3000 for AI Studio)
PORT=3000

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Nodemailer Configuration (Use an App Password for Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# App URL (Injected by AI Studio)
APP_URL=http://localhost:3000
